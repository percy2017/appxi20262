<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Admin MotoTaxi' %></title>
    <!-- jQuery (cargarlo primero) -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- Bootstrap 5.0 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- DataTables CSS -->
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="/css/admin/admin.css" rel="stylesheet">
</head>
<body>
    
    <!-- Top Header -->
    <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow">
        <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3" href="/admin">
            <i class="bi bi-speedometer2 me-2"></i>Appxi Admin
        </a>
        <button class="navbar-toggler position-absolute d-md-none collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="w-100"></div>
        <% if (typeof usuario !== 'undefined' && usuario) { %>
        <div class="navbar-nav">
            <div class="nav-item text-nowrap d-flex align-items-center">
                <span class="nav-link text-white me-3">
                    <i class="bi bi-person-circle me-1"></i>
                    <%= usuario.nombre || usuario.username %>
                </span>
                <a class="nav-link text-danger" href="/admin/logout">
                    <i class="bi bi-box-arrow-right me-1"></i>Salir
                </a>
            </div>
        </div>
        <% } %>
    </header>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse">
                <div class="position-sticky">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>" href="/admin">
                                <i class="bi bi-speedometer2"></i> Panel
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'viajes' ? 'active' : '' %>" href="/admin/viajes">
                                <i class="bi bi-car-front"></i> Viajes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'pilotos' ? 'active' : '' %>" href="/admin/pilotos">
                                <i class="bi bi-people"></i> Choferes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'pasajeros' ? 'active' : '' %>" href="/admin/pasajeros">
                                <i class="bi bi-person"></i> Pasajeros
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'usuarios' ? 'active' : '' %>" href="/admin/usuarios">
                                <i class="bi bi-shield-lock"></i> Usuarios
                            </a>
                        </li>
                      
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'socket-monitor' ? 'active' : '' %>" href="/admin/socket-monitor">
                                <i class="bi bi-diagram-3"></i> Sockets
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'evolution' ? 'active' : '' %>" href="/admin/evolution">
                                <i class="bi bi-whatsapp"></i> Evolution
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <%- body %>
            </main>
        </div>
    </div>


    <!-- Bootstrap 5.0 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <!-- Socket.io Client -->
    <script src="/socket.io/socket.io.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Variables globales desde configuración -->
    <script>
        // Variables de configuración del servidor
        window.MONEDA = '<%= MONEDA || "Bs" %>';
        window.PRECIO_BASE = Number('<%= PRECIO_BASE %>') || 5;
    </script>
    <!-- Socket Client (sin export para uso en navegador) -->
    <script src="/js/socket-client.js"></script>
    <!-- Dashboard Admin JS -->
    <script src="/js/admin/dashboard.js"></script>
</body>
</html>
