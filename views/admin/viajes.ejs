<!-- Vista Viajes - Gestión de Viajes del Sistema -->
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-geo-alt"></i> Gestión de Viajes</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="exportarViajes()">
                <i class="bi bi-download"></i> Exportar
            </button>
        </div>
    </div>
</div>

<!-- Tabla de Viajes (carga AJAX para tiempo real) -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <span><i class="bi bi-geo-alt"></i> Lista de Viajes</span>
        <div>
            <span class="badge bg-light text-dark" id="viajesCount">Cargando...</span>
            <button class="btn btn-sm btn-light ms-2" onclick="recargarViajes()" title="Actualizar">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="viajesTable" class="table table-striped table-hover" style="width:100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Pasajero</th>
                        <th>Piloto</th>
                        <th>Origen</th>
                        <th>Destino</th>
                        <th>Distancia</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="viajesTableBody">
                    <!-- Los datos se cargan vía AJAX desde dashboard.js -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal para Ver Detalles del Viaje -->
<div class="modal fade" id="viajeDetalleModal" tabindex="-1" aria-labelledby="viajeDetalleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="viajeDetalleModalLabel">
                    <i class="bi bi-geo-alt me-2"></i>Detalles del Viaje
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="viajeDetalleContenido">
                <!-- Contenido dinámico -->
            </div>
            <div class="modal-footer bg-light py-3">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-2"></i>Cerrar
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Datos locales para el modal de detalles
    let todosLosViajes = [];

    // Función para cargar viajes (usada por dashboard.js)
    window.cargarViajesData = function() {
        $.ajax({
            url: '/admin/api/viajes',
            method: 'GET',
            success: function(response) {
                if (response.success) {
                    todosLosViajes = response.data;
                    $('#viajesCount').text(response.data.length + ' viajes');
                }
            },
            error: function() {
                console.error('Error al cargar viajes');
            }
        });
    };

    // Ver detalles del viaje
    function verViaje(id) {
        const viajeId = parseInt(id);
        const viaje = todosLosViajes.find(v => v.id === viajeId);
        
        if (!viaje) {
            Swal.fire('Error', 'No se encontró el viaje', 'error');
            return;
        }
        
        // Determinar estado
        let estadoBadge = 'secondary';
        let estadoIcon = '⚪';
        let estadoTexto = viaje.estado;
        
        switch(viaje.estado) {
            case 'pendiente':
                estadoBadge = 'warning';
                estadoIcon = '⏳';
                estadoTexto = 'Pendiente';
                break;
            case 'aceptado':
                estadoBadge = 'info';
                estadoIcon = '✅';
                estadoTexto = 'Aceptado';
                break;
            case 'encurso':
                estadoBadge = 'primary';
                estadoIcon = '🚗';
                estadoTexto = 'En Curso';
                break;
            case 'completado':
                estadoBadge = 'success';
                estadoIcon = '🎉';
                estadoTexto = 'Completado';
                break;
            case 'cancelado':
                estadoBadge = 'danger';
                estadoIcon = '❌';
                estadoTexto = 'Cancelado';
                break;
        }
        
        // Formatear fechas
        const fechaSolicitud = viaje.fecha_solicitud ? new Date(viaje.fecha_solicitud).toLocaleString('es-BO') : '-';
        const fechaInicio = viaje.fecha_inicio ? new Date(viaje.fecha_inicio).toLocaleString('es-BO') : '-';
        const fechaFin = viaje.fecha_fin ? new Date(viaje.fecha_fin).toLocaleString('es-BO') : '-';
        
        // Construir contenido del modal
        const contenido = `
            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="p-3 bg-light rounded">
                        <h6 class="text-uppercase text-muted mb-2">
                            <i class="bi bi-hash"></i> ID del Viaje
                        </h6>
                        <h4 class="mb-0">#${viaje.id}</h4>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="p-3 bg-light rounded">
                        <h6 class="text-uppercase text-muted mb-2">
                            <i class="bi bi-info-circle"></i> Estado
                        </h6>
                        <span class="badge bg-${estadoBadge} fs-6">
                            ${estadoIcon} ${estadoTexto}
                        </span>
                    </div>
                </div>
            </div>
            
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-person"></i> Pasajero
                        </h6>
                        <div class="d-flex align-items-center p-2 bg-light rounded">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold me-2" style="width:40px;height:40px; background: #0dcaf0;">
                                ${viaje.pasajero_nombre ? viaje.pasajero_nombre.charAt(0).toUpperCase() : '?'}
                            </div>
                            <div>
                                <strong>${viaje.pasajero_nombre || 'Sin asignar'}</strong><br>
                                <small class="text-muted">${viaje.pasajero_telefono || '-'}</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-car-front"></i> Piloto
                        </h6>
                        <div class="d-flex align-items-center p-2 bg-light rounded">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold me-2" style="width:40px;height:40px; background: #198754;">
                                ${viaje.piloto_nombre ? viaje.piloto_nombre.charAt(0).toUpperCase() : '?'}
                            </div>
                            <div>
                                <strong>${viaje.piloto_nombre || 'Sin asignar'}</strong><br>
                                <small class="text-muted">${viaje.piloto_telefono || '-'}</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="row mt-2">
                <div class="col-md-6">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-geo-alt"></i> Origen
                        </h6>
                        <div class="p-2 bg-light rounded">
                            <small>${viaje.origen_direccion || '-'}</small>
                            <br>
                            <small class="text-muted">
                                Lat: ${viaje.origen_lat ? viaje.origen_lat.toFixed(6) : '-'}, 
                                Lng: ${viaje.origen_lng ? viaje.origen_lng.toFixed(6) : '-'}
                            </small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-geo-alt-fill"></i> Destino
                        </h6>
                        <div class="p-2 bg-light rounded">
                            <small>${viaje.destino_direccion || '-'}</small>
                            <br>
                            <small class="text-muted">
                                Lat: ${viaje.destino_lat ? viaje.destino_lat.toFixed(6) : '-'}, 
                                Lng: ${viaje.destino_lng ? viaje.destino_lng.toFixed(6) : '-'}
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="row mt-2">
                <div class="col-md-4">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-signpost-2"></i> Distancia
                        </h6>
                        <div class="p-2 bg-light rounded">
                            <strong>${viaje.distancia ? viaje.distancia.toFixed(2) + ' km' : '-'}</strong>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-currency-dollar"></i> Precio
                        </h6>
                        <div class="p-2 bg-light rounded">
                            <strong class="text-success">${viaje.precio ? MONEDA + ' ' + viaje.precio.toFixed(2) : '-'}</strong>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-cash"></i> Costo
                        </h6>
                        <div class="p-2 bg-light rounded">
                            <strong>${viaje.precio ? MONEDA + ' ' + viaje.precio.toFixed(2) : '-'}</strong>
                        </div>
                    </div>
                </div>
            </div>
            
            <hr>
            
            <div class="row mt-2">
                <div class="col-md-4">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-clock"></i> Fecha Solicitud
                        </h6>
                        <small>${fechaSolicitud}</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-play-circle"></i> Fecha Inicio
                        </h6>
                        <small>${fechaInicio}</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.75rem;">
                            <i class="bi bi-check-circle"></i> Fecha Fin
                        </h6>
                        <small>${fechaFin}</small>
                    </div>
                </div>
            </div>
        `;
        
        document.getElementById('viajeDetalleContenido').innerHTML = contenido;
        
        // Mostrar modal
        const modal = new bootstrap.Modal(document.getElementById('viajeDetalleModal'));
        modal.show();
    }

    // Cancelar viaje
    function cancelarViaje(id) {
        const viajeId = parseInt(id);
        
        Swal.fire({
            title: '¿Estás seguro?',
            text: '¿Deseas cancelar este viaje? Esta acción no se puede deshacer.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Sí, cancelar',
            cancelButtonText: 'No, mantener'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: `/admin/api/viajes/${viajeId}/cancelar`,
                    method: 'POST',
                    success: function(response) {
                        if (response.success) {
                            Swal.fire('Éxito', response.message, 'success').then(() => {
                                recargarViajes();
                            });
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function(xhr) {
                        const response = xhr.responseJSON;
                        Swal.fire('Error', response?.message || 'Error al cancelar el viaje', 'error');
                    }
                });
            }
        });
    }

    // Completar viaje
    function completarViaje(id) {
        const viajeId = parseInt(id);
        
        Swal.fire({
            title: '¿Completar viaje?',
            text: '¿Deseas marcar este viaje como completado?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#198754',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Sí, completar',
            cancelButtonText: 'No, aún no'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: `/admin/api/viajes/${viajeId}/completar`,
                    method: 'POST',
                    success: function(response) {
                        if (response.success) {
                            Swal.fire('Éxito', response.message, 'success').then(() => {
                                recargarViajes();
                            });
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function(xhr) {
                        const response = xhr.responseJSON;
                        Swal.fire('Error', response?.message || 'Error al completar el viaje', 'error');
                    }
                });
            }
        });
    }

    // Exportar viajes
    function exportarViajes() {
        window.location.href = '/admin/api/viajes?export=true';
    }
</script>
