 <!-- Vista Usuarios - Solo contenido principal -->
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-shield-lock"></i> Gestión de Usuarios</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="exportarUsuarios()">
                <i class="bi bi-download"></i> Exportar
            </button>
        </div>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#usuarioModal" onclick="limpiarFormulario()">
            <i class="bi bi-plus-circle"></i> Nuevo Usuario
        </button>
    </div>
</div>

<!-- Tabla de Usuarios -->
<div class="card mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table id="usuariosTable" class="table table-striped table-hover" style="width:100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Avatar</th>
                        <th>Usuario</th>
                        <th>Nombre</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (usuarios && usuarios.length > 0) { %>
                        <% usuarios.forEach(function(usuario) { %>
                            <tr>
                                <td class="align-middle"><%= usuario.id %></td>
                                <td class="align-middle">
                                    <% if (usuario.avatar) { %>
                                        <img src="<%= usuario.avatar %>" alt="Avatar" class="rounded-circle" width="40" height="40" style="object-fit: cover;">
                                    <% } else { %>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:40px;height:40px; background: <%= usuario.rol === 'administrador' ? '#dc3545' : usuario.rol === 'chofer' ? '#198754' : '#0dcaf0' %>;">
                                            <%= usuario.nombre ? usuario.nombre.charAt(0).toUpperCase() : 'U' %>
                                        </div>
                                    <% } %>
                                </td>
                                <td class="align-middle"><strong><%= usuario.username %></strong></td>
                                <td class="align-middle"><%= usuario.nombre %></td>
                                <td class="align-middle"><%= usuario.telefono || '-' %></td>
                                <td class="align-middle"><%= usuario.email || '-' %></td>
                                <td class="align-middle">
                                    <span class="badge bg-<%= usuario.rol === 'administrador' ? 'danger' : usuario.rol === 'chofer' ? 'success' : 'info' %>">
                                        <%= usuario.rol === 'administrador' ? '👤' : usuario.rol === 'chofer' ? '🚗' : '🎫' %>
                                        <%= usuario.rol.charAt(0).toUpperCase() + usuario.rol.slice(1) %>
                                    </span>
                                </td>
                                <td class="align-middle">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#usuarioModal" onclick="editarUsuario(<%= usuario.id %>)" title="Editar">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" onclick="eliminarUsuario(<%= usuario.id %>)" title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                       
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal para Crear/Editar Usuario -->
<div class="modal fade" id="usuarioModal" tabindex="-1" aria-labelledby="usuarioModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="usuarioModalLabel">
                    <i class="bi bi-person-plus me-2"></i>Nuevo Usuario
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="usuarioForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="usuarioId">
                    
                    <!-- Sección: Información Personal -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-person-vcard me-1"></i> Información Personal
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="nombre" class="form-label fw-semibold">
                                    Nombre Completo <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-person-fill"></i></span>
                                    <input type="text" class="form-control" id="nombre" placeholder="Ej: Juan Pérez" required>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="telefono" class="form-label fw-semibold">
                                    Teléfono
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-telephone-fill"></i></span>
                                    <input type="text" class="form-control" id="telefono" placeholder="Ej: 76543210">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Contacto -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-envelope me-1"></i> Información de Contacto
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="email" class="form-label fw-semibold">
                                    Correo Electrónico
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light">@</span>
                                    <input type="email" class="form-control" id="email" placeholder="correo@ejemplo.com">
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="avatar" class="form-label fw-semibold">
                                    Avatar (URL)
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-image-fill"></i></span>
                                    <input type="text" class="form-control" id="avatar" placeholder="https://ejemplo.com/avatar.jpg">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Credenciales -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-key me-1"></i> Credenciales de Acceso
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="username" class="form-label fw-semibold">
                                    Usuario <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-at"></i></span>
                                    <input type="text" class="form-control" id="username" placeholder="Nombre de usuario" required>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="rol" class="form-label fw-semibold">
                                    Rol <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-shield-lock-fill"></i></span>
                                    <select class="form-select" id="rol">
                                        <option value="administrador">👤 Administrador</option>
                                        <option value="chofer">🚗 Chofer</option>
                                        <option value="pasajero">🎫 Pasajero</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Contraseña -->
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-lock me-1"></i> Seguridad
                        </h6>
                        
                        <div class="row">
                            <div class="col-12">
                                <label for="password" class="form-label fw-semibold">
                                    Contraseña <span id="passwordRequired" class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-asterisk"></i></span>
                                    <input type="password" class="form-control" id="password" placeholder="Mínimo 6 caracteres">
                                </div>
                                <div class="form-text" id="passwordHelp">Dejar en blanco para mantener la contraseña actual (solo en edición)</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light py-3">
                    <button type="button" class="btn btn-lg btn-outline-secondary px-4" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-2"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-lg btn-primary px-4">
                        <i class="bi bi-check-circle me-2"></i>Guardar Usuario
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Inicializar DataTable
    $(document).ready(function() {
        $('#usuariosTable').DataTable({
            language: {
                url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
            },
            order: [[0, 'desc']]
        });
    });

    // Limpiar formulario
    function limpiarFormulario() {
        $('#usuarioId').val('');
        $('#usuarioForm')[0].reset();
        $('#usuarioModalLabel').text('Nuevo Usuario');
        $('#passwordRequired').show();
        $('#passwordHelp').hide();
        $('#password').attr('required', true);
        $('#telefono').val('');
        $('#avatar').val('');
    }

    // Editar usuario
    function editarUsuario(id) {
        // Asegurar que el ID sea un número
        const usuarioId = parseInt(id);
        
        $.ajax({
            url: '/admin/api/usuarios',
            method: 'GET',
            success: function(response) {
                if (response.success) {
                    const usuario = response.data.find(u => u.id === usuarioId);
                    if (usuario) {
                        $('#usuarioId').val(usuario.id);
                        $('#username').val(usuario.username);
                        $('#nombre').val(usuario.nombre);
                        $('#email').val(usuario.email || '');
                        $('#telefono').val(usuario.telefono || '');
                        $('#avatar').val(usuario.avatar || '');
                        $('#rol').val(usuario.rol);
                        $('#password').attr('required', false);
                        $('#passwordRequired').hide();
                        $('#passwordHelp').show();
                        $('#usuarioModalLabel').text('Editar Usuario');
                    }
                }
            },
            error: function() {
                Swal.fire('Error', 'No se pudo cargar el usuario', 'error');
            }
        });
    }

    // Guardar usuario (crear o actualizar)
    $('#usuarioForm').on('submit', function(e) {
        e.preventDefault();
        console.log('Formulario enviado');
        
        // Obtener el ID y convertirlo a número
        const idValue = $('#usuarioId').val();
        const id = idValue ? parseInt(idValue) : null;
        const password = $('#password').val();
        
        console.log('ID:', id, 'Password:', password ? '****' : 'vacío');
        
        // Validar que tenga contraseña si es nuevo usuario
        if (!id && !password) {
            Swal.fire('Error', 'La contraseña es requerida para nuevos usuarios', 'error');
            return;
        }
        
        const usuario = {
            username: $('#username').val(),
            nombre: $('#nombre').val(),
            email: $('#email').val(),
            telefono: $('#telefono').val(),
            avatar: $('#avatar').val(),
            rol: $('#rol').val()
        };
        
        console.log('Datos usuario:', usuario);
        
        // Agregar password si tiene valor o si es nuevo usuario
        if (password) {
            usuario.password = password;
        }
        
        const url = id ? `/admin/api/usuarios/${id}` : '/admin/api/usuarios';
        const method = id ? 'PUT' : 'POST';
        
        console.log('Enviando a:', url, 'método:', method);
        
        $.ajax({
            url: url,
            method: method,
            contentType: 'application/json',
            data: JSON.stringify(usuario),
            success: function(response) {
                console.log('Respuesta:', response);
                if (response.success) {
                    Swal.fire('Éxito', response.message, 'success').then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            },
            error: function(xhr) {
                console.log('Error:', xhr);
                const response = xhr.responseJSON;
                Swal.fire('Error', response?.message || 'Error al guardar el usuario: ' + (response?.error || ''), 'error');
            }
        });
    });

    // Eliminar usuario
    function eliminarUsuario(id) {
        // Asegurar que el ID sea un número
        const usuarioId = parseInt(id);
        
        Swal.fire({
            title: '¿Estás seguro?',
            text: 'Esta acción no se puede deshacer',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: `/admin/api/usuarios/${usuarioId}`,
                    method: 'DELETE',
                    success: function(response) {
                        if (response.success) {
                            Swal.fire('Eliminado', response.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function(xhr) {
                        const response = xhr.responseJSON;
                        Swal.fire('Error', response?.message || 'Error al eliminar el usuario', 'error');
                    }
                });
            }
        });
    }

    // Exportar usuarios
    function exportarUsuarios() {
        window.location.href = '/admin/api/usuarios?export=true';
    }
</script>
