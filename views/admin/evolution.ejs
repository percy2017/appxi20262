<!-- Vista Evolution API - Instancias de WhatsApp -->
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-whatsapp"></i> Evolution API</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise"></i> Actualizar
        </button>
    </div>
</div>

<!-- Información de Conexión -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <i class="bi bi-info-circle"></i> Configuración
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <p><strong>URL del Servidor:</strong> <%= apiUrl %></p>
            </div>
            <div class="col-md-4">
                <p><strong>Token:</strong> ********</p>
            </div>
            <div class="col-md-4">
                <p><strong>Instancia por defecto:</strong> 
                    <% if (typeof defaultInstance !== 'undefined' && defaultInstance) { %>
                        <span class="badge bg-primary"><%= defaultInstance %></span>
                    <% } else { %>
                        <span class="badge bg-secondary">No configurada</span>
                    <% } %>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Error de Conexión -->
<% if (error) { %>
<div class="alert alert-danger" role="alert">
    <i class="bi bi-exclamation-triangle"></i> <%= error %>
</div>
<% } %>

<!-- Debug: Mostrar datos crudos (solo en desarrollo) -->
<% if (typeof instances !== 'undefined') { %>
<div class="card mb-4 d-none">
    <div class="card-header bg-secondary text-white hidden">
        <i class="bi bi-bug"></i> Debug: Datos Recibidos
    </div>
    <div class="card-body">
        <pre><%= JSON.stringify(instances, null, 2) %></pre>
    </div>
</div>
<% } %>

<!-- Lista de Instancias -->
<div class="card mb-4">
    <div class="card-header bg-success text-white">
        <i class="bi bi-hdd-stack"></i> Instancias Disponibles
    </div>
    <div class="card-body">
        <% if (instances && instances.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Seleccionar</th>
                            <th>Nombre</th>
                            <th>Estado</th>
                            <th>Dueño (WhatsApp)</th>
                            <th>Perfil</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% instances.forEach(function(instance) { %>
                            <tr>
                                <td>
                                    <input type="radio" name="selectedInstance" value="<%= instance.instanceName %>" 
                                        class="form-check-input instance-selector" 
                                        data-name="<%= instance.instanceName %>"
                                        <%= (typeof defaultInstance !== 'undefined' && defaultInstance === instance.instanceName) ? 'checked' : '' %>>
                                </td>
                                <td><strong><%= instance.instanceName %></strong></td>
                                <td>
                                    <% if (instance.state === 'open') { %>
                                        <span class="badge bg-success">Conectada</span>
                                    <% } else if (instance.state === 'close') { %>
                                        <span class="badge bg-danger">Desconectada</span>
                                    <% } else { %>
                                        <span class="badge bg-warning"><%= instance.state || 'Desconocido' %></span>
                                    <% } %>
                                </td>
                                <td><%= instance.owner || 'N/A' %></td>
                                <td><%= instance.profileName || 'N/A' %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-4">
                <i class="bi bi-inbox" style="font-size: 3rem; color: #6c757d;"></i>
                <p class="mt-2 text-muted">No se encontraron instancias</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Notas -->
<div class="card">
    <div class="card-header bg-info text-white">
        <i class="bi bi-lightbulb"></i> Información
    </div>
    <div class="card-body">
        <ul>
            <li>Selecciona la instancia que se usará para enviar PINs de verificación</li>
            <li>Si no seleccionas ninguna, el sistema usará automáticamente una instancia "Conectada"</li>
            <li>Las instancias permiten enviar y recibir mensajes de WhatsApp</li>
        </ul>
    </div>
</div>

<!-- Script para manejar selección de instancia -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const selectors = document.querySelectorAll('.instance-selector');
    
    selectors.forEach(function(checkbox) {
        checkbox.addEventListener('change', function() {
            if (this.checked) {
                const instanceName = this.dataset.name;
                
                // Llamar API para guardar la selección
                fetch('/api/evolution/set-default', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ instance: instanceName })
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Instancia seleccionada',
                            text: 'Ahora se usará "' + instanceName + '" para enviar notificaciones',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.message || 'Error al guardar'
                        });
                    }
                })
                .catch(function(err) {
                    console.error('Error:', err);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Error de conexión'
                    });
                });
            }
        });
    });
});
</script>
