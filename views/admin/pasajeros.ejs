<!-- Vista Pasajeros - Gestión de Pasajeros -->
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-people"></i> Gestión de Pasajeros</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="exportarPasajeros()">
                <i class="bi bi-download"></i> Exportar
            </button>
        </div>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#pasajeroModal" onclick="limpiarFormulario()">
            <i class="bi bi-plus-circle"></i> Nuevo Pasajero
        </button>
    </div>
</div>

<!-- Tabla de Pasajeros -->
<div class="card mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table id="pasajerosTable" class="table table-striped table-hover" style="width:100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Avatar</th>
                        <th>Nombre</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Verificado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (pasajeros && pasajeros.length > 0) { %>
                        <% pasajeros.forEach(function(pasajero) { %>
                            <tr>
                                <td class="align-middle"><%= pasajero.id %></td>
                                <td class="align-middle">
                                    <% if (pasajero.avatar) { %>
                                        <img src="<%= pasajero.avatar %>" alt="Avatar" class="rounded-circle" width="40" height="40" style="object-fit: cover;">
                                    <% } else { %>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:40px;height:40px; background: #0dcaf0;">
                                            <%= pasajero.nombre ? pasajero.nombre.charAt(0).toUpperCase() : 'P' %>
                                        </div>
                                    <% } %>
                                </td>
                                <td class="align-middle"><strong><%= pasajero.nombre %></strong></td>
                                <td class="align-middle"><%= pasajero.telefono %></td>
                                <td class="align-middle"><%= pasajero.email || '-' %></td>
                                <td class="align-middle">
                                    <% if (pasajero.avatar) { %>
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Verificado</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary"><i class="bi bi-question-circle"></i> No</span>
                                    <% } %>
                                </td>
                                <td class="align-middle">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#pasajeroModal" onclick="editarPasajero(<%= pasajero.id %>)" title="Editar">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" onclick="eliminarPasajero(<%= pasajero.id %>)" title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                       
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal para Crear/Editar Pasajero -->
<div class="modal fade" id="pasajeroModal" tabindex="-1" aria-labelledby="pasajeroModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="pasajeroModalLabel">
                    <i class="bi bi-person-plus me-2"></i>Nuevo Pasajero
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="pasajeroForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="pasajeroId">
                    
                    <!-- Sección: Información Personal -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-person-vcard me-1"></i> Información Personal
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="nombre" class="form-label fw-semibold">
                                    Nombre Completo <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-person-fill"></i></span>
                                    <input type="text" class="form-control" id="nombre" placeholder="Ej: Juan Pérez" required>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="telefono" class="form-label fw-semibold">
                                    Teléfono <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-telephone-fill"></i></span>
                                    <input type="text" class="form-control" id="telefono" placeholder="Ej: 76543210" required>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Contacto -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-envelope me-1"></i> Información de Contacto
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="email" class="form-label fw-semibold">
                                    Correo Electrónico
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light">@</span>
                                    <input type="email" class="form-control" id="email" placeholder="correo@ejemplo.com">
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="avatar" class="form-label fw-semibold">
                                    Avatar (URL)
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-image-fill"></i></span>
                                    <input type="text" class="form-control" id="avatar" placeholder="https://ejemplo.com/avatar.jpg">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Dirección -->
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-geo-alt me-1"></i> Dirección
                        </h6>
                        
                        <div class="row">
                            <div class="col-12">
                                <label for="direccion" class="form-label fw-semibold">
                                    Dirección
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-house-fill"></i></span>
                                    <input type="text" class="form-control" id="direccion" placeholder="Dirección de casa u oficina">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light py-3">
                    <button type="button" class="btn btn-lg btn-outline-secondary px-4" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-2"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-lg btn-primary px-4">
                        <i class="bi bi-check-circle me-2"></i>Guardar Pasajero
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Inicializar DataTable
    $(document).ready(function() {
        try {
            if ($.fn.DataTable.isDataTable('#pasajerosTable')) {
                $('#pasajerosTable').DataTable().destroy();
            }
            $('#pasajerosTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                order: [[0, 'desc']],
                destroy: true,
                // Ignorar HTML en el procesamiento
                "bProcessing": false
            });
        } catch(e) {
            console.log('DataTables error:', e);
            // Si falla DataTables, usar tabla simple
        }
    });

    // Limpiar formulario
    function limpiarFormulario() {
        $('#pasajeroId').val('');
        $('#pasajeroForm')[0].reset();
        $('#pasajeroModalLabel').text('Nuevo Pasajero');
    }

    // Editar pasajero
    function editarPasajero(id) {
        const pasajeroId = parseInt(id);
        
        $.ajax({
            url: '/admin/api/pasajeros',
            method: 'GET',
            success: function(response) {
                if (response.success) {
                    const pasajero = response.data.find(p => p.id === pasajeroId);
                    if (pasajero) {
                        $('#pasajeroId').val(pasajero.id);
                        $('#nombre').val(pasajero.nombre);
                        $('#telefono').val(pasajero.telefono);
                        $('#email').val(pasajero.email || '');
                        $('#direccion').val(pasajero.direccion || '');
                        $('#avatar').val(pasajero.avatar || '');
                        $('#pasajeroModalLabel').text('Editar Pasajero');
                    }
                }
            },
            error: function() {
                Swal.fire('Error', 'No se pudo cargar el pasajero', 'error');
            }
        });
    }

    // Guardar pasajero (crear o actualizar)
    $('#pasajeroForm').on('submit', function(e) {
        e.preventDefault();
        
        const idValue = $('#pasajeroId').val();
        const id = idValue ? parseInt(idValue) : null;
        
        const pasajero = {
            nombre: $('#nombre').val(),
            telefono: $('#telefono').val(),
            email: $('#email').val(),
            direccion: $('#direccion').val(),
            avatar: $('#avatar').val()
        };
        
        const url = id ? `/admin/api/pasajeros/${id}` : '/admin/api/pasajeros';
        const method = id ? 'PUT' : 'POST';
        
        $.ajax({
            url: url,
            method: method,
            contentType: 'application/json',
            data: JSON.stringify(pasajero),
            success: function(response) {
                if (response.success) {
                    Swal.fire('Éxito', response.message, 'success').then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            },
            error: function(xhr) {
                const response = xhr.responseJSON;
                Swal.fire('Error', response?.message || 'Error al guardar el pasajero', 'error');
            }
        });
    });

    // Eliminar pasajero
    function eliminarPasajero(id) {
        const pasajeroId = parseInt(id);
        
        Swal.fire({
            title: '¿Estás seguro?',
            text: 'Esta acción no se puede deshacer',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: `/admin/api/pasajeros/${pasajeroId}`,
                    method: 'DELETE',
                    success: function(response) {
                        if (response.success) {
                            Swal.fire('Eliminado', response.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function(xhr) {
                        const response = xhr.responseJSON;
                        Swal.fire('Error', response?.message || 'Error al eliminar el pasajero', 'error');
                    }
                });
            }
        });
    }

    // Exportar pasajeros
    function exportarPasajeros() {
        window.location.href = '/admin/api/pasajeros?export=true';
    }
</script>
