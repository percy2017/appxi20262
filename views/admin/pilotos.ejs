<!-- Vista Pilotos - Gestión de Pilotos de Mototaxi -->
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-people"></i> Gestión de Pilotos</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="exportarPilotos()">
                <i class="bi bi-download"></i> Exportar
            </button>
        </div>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#pilotoModal" onclick="limpiarFormulario()">
            <i class="bi bi-plus-circle"></i> Nuevo Piloto
        </button>
    </div>
</div>

<!-- Tabla de Pilotos -->
<div class="card mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table id="pilotosTable" class="table table-striped table-hover" style="width:100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Foto</th>
                        <th>Nombre</th>
                        <th>Teléfono</th>
                        <th>Licencia</th>
                        <th>Placa</th>
                        <th>Vehículo</th>
                        <th>Foto Vehículo</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (pilotos && pilotos.length > 0) { %>
                        <% pilotos.forEach(function(piloto) { %>
                            <tr>
                                <td class="align-middle"><%= piloto.id %></td>
                                <td class="align-middle">
                                    <% if (piloto.foto) { %>
                                        <img src="<%= piloto.foto %>" alt="Foto" class="rounded-circle" width="40" height="40" style="object-fit: cover;">
                                    <% } else { %>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:40px;height:40px; background: <%= piloto.estado === 'disponible' ? '#198754' : piloto.estado === 'ocupado' ? '#dc3545' : '#6c757d' %>;">
                                            <%= piloto.nombre ? piloto.nombre.charAt(0).toUpperCase() : 'P' %>
                                        </div>
                                    <% } %>
                                </td>
                                <td class="align-middle"><strong><%= piloto.nombre %></strong></td>
                                <td class="align-middle"><%= piloto.telefono %></td>
                                <td class="align-middle"><%= piloto.licencia %></td>
                                <td class="align-middle"><span class="badge bg-dark"><%= piloto.placa %></span></td>
                                <td class="align-middle">
                                    <%= piloto.modelo || '-' %>
                                    <% if (piloto.color) { %>
                                        <span class="badge ms-1" style="background-color: <%= piloto.color %>; color: <%= ['#ffffff', '#ffff00', '#f0f0f0'].includes(piloto.color) ? '#000' : '#fff' %>;">
                                            <i class="bi bi-palette-fill"></i>
                                        </span>
                                    <% } %>
                                </td>
                                <td class="align-middle">
                                    <% if (piloto.foto_vehiculo) { %>
                                        <img src="<%= piloto.foto_vehiculo %>" alt="Vehículo" class="rounded" width="60" height="40" style="object-fit: cover;">
                                    <% } else { %>
                                        <span class="text-muted">-</span>
                                    <% } %>
                                </td>
                                <td class="align-middle">
                                    <span class="badge bg-<%= piloto.estado === 'disponible' ? 'success' : piloto.estado === 'ocupado' ? 'danger' : 'secondary' %>">
                                        <%= piloto.estado === 'disponible' ? '✅' : piloto.estado === 'ocupado' ? '🔴' : '⚪' %>
                                        <%= piloto.estado.charAt(0).toUpperCase() + piloto.estado.slice(1) %>
                                    </span>
                                </td>
                                <td class="align-middle">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#pilotoModal" onclick="editarPiloto(<%= piloto.id %>)" title="Editar">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" onclick="eliminarPiloto(<%= piloto.id %>)" title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal para Crear/Editar Piloto -->
<div class="modal fade" id="pilotoModal" tabindex="-1" aria-labelledby="pilotoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="pilotoModalLabel">
                    <i class="bi bi-person-plus me-2"></i>Nuevo Piloto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="pilotoForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="pilotoId">
                    
                    <!-- Sección: Información Personal -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-person-vcard me-1"></i> Información Personal
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="nombre" class="form-label fw-semibold">
                                    Nombre Completo <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-person-fill"></i></span>
                                    <input type="text" class="form-control" id="nombre" placeholder="Ej: Juan Pérez" required>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="telefono" class="form-label fw-semibold">
                                    Teléfono <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-telephone-fill"></i></span>
                                    <input type="text" class="form-control" id="telefono" placeholder="Ej: 76543210" required>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row g-3 mt-2">
                            <div class="col-12">
                                <label for="foto" class="form-label fw-semibold">
                                    Foto del Piloto (URL)
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-camera-fill"></i></span>
                                    <input type="text" class="form-control" id="foto" placeholder="https://ejemplo.com/foto.jpg">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Licencia -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-credit-card me-1"></i> Licencia
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-12">
                                <label for="licencia" class="form-label fw-semibold">
                                    Número de Licencia <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-upc-scan"></i></span>
                                    <input type="text" class="form-control" id="licencia" placeholder="Número de licencia" required>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Vehículo -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-car-front me-1"></i> Información del Vehículo
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="placa" class="form-label fw-semibold">
                                    Placa <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-upc-scan"></i></span>
                                    <input type="text" class="form-control" id="placa" placeholder="Ej: ABC-123" required>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <label for="modelo" class="form-label fw-semibold">
                                    Modelo
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-car-front-fill"></i></span>
                                    <input type="text" class="form-control" id="modelo" placeholder="Ej: Honda PCX">
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <label for="color" class="form-label fw-semibold">
                                    Color
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-palette-fill"></i></span>
                                    <input type="color" class="form-control form-control-color" id="color" value="#000000" title="Elegir color">
                                </div>
                            </div>
                        </div>
                        
                        <div class="row g-3 mt-2">
                            <div class="col-12">
                                <label for="foto_vehiculo" class="form-label fw-semibold">
                                    Foto del Vehículo (URL)
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-car-front"></i></span>
                                    <input type="text" class="form-control" id="foto_vehiculo" placeholder="https://ejemplo.com/vehiculo.jpg">
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Estado -->
                    <div class="mb-3">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-info-circle me-1"></i> Estado
                        </h6>
                        
                        <div class="row">
                            <div class="col-12">
                                <label for="estado" class="form-label fw-semibold">
                                    Estado del Piloto <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-toggle-on"></i></span>
                                    <select class="form-select" id="estado">
                                        <option value="disponible">✅ Disponible</option>
                                        <option value="ocupado">🔴 Ocupado</option>
                                        <option value="inactivo">⚪ Inactivo</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light py-3">
                    <button type="button" class="btn btn-lg btn-outline-secondary px-4" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-2"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-lg btn-primary px-4">
                        <i class="bi bi-check-circle me-2"></i>Guardar Piloto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Inicializar DataTable
    $(document).ready(function() {
        $('#pilotosTable').DataTable({
            language: {
                url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
            },
            order: [[0, 'desc']]
        });
    });

    // Limpiar formulario
    function limpiarFormulario() {
        $('#pilotoId').val('');
        $('#pilotoForm')[0].reset();
        $('#pilotoModalLabel').text('Nuevo Piloto');
        $('#color').val('#000000');
    }

    // Editar piloto
    function editarPiloto(id) {
        const pilotoId = parseInt(id);
        
        $.ajax({
            url: '/admin/api/pilotos',
            method: 'GET',
            success: function(response) {
                if (response.success) {
                    const piloto = response.data.find(p => p.id === pilotoId);
                    if (piloto) {
                        $('#pilotoId').val(piloto.id);
                        $('#nombre').val(piloto.nombre);
                        $('#telefono').val(piloto.telefono);
                        $('#licencia').val(piloto.licencia);
                        $('#placa').val(piloto.placa);
                        $('#modelo').val(piloto.modelo || '');
                        $('#color').val(piloto.color || '#000000');
                        $('#foto').val(piloto.foto || '');
                        $('#foto_vehiculo').val(piloto.foto_vehiculo || '');
                        $('#estado').val(piloto.estado);
                        $('#pilotoModalLabel').text('Editar Piloto');
                    }
                }
            },
            error: function() {
                Swal.fire('Error', 'No se pudo cargar el piloto', 'error');
            }
        });
    }

    // Guardar piloto (crear o actualizar)
    $('#pilotoForm').on('submit', function(e) {
        e.preventDefault();
        
        const idValue = $('#pilotoId').val();
        const id = idValue ? parseInt(idValue) : null;
        
        const piloto = {
            nombre: $('#nombre').val(),
            telefono: $('#telefono').val(),
            licencia: $('#licencia').val(),
            placa: $('#placa').val(),
            modelo: $('#modelo').val(),
            color: $('#color').val(),
            foto: $('#foto').val(),
            foto_vehiculo: $('#foto_vehiculo').val(),
            estado: $('#estado').val()
        };
        
        const url = id ? `/admin/api/pilotos/${id}` : '/admin/api/pilotos';
        const method = id ? 'PUT' : 'POST';
        
        $.ajax({
            url: url,
            method: method,
            contentType: 'application/json',
            data: JSON.stringify(piloto),
            success: function(response) {
                if (response.success) {
                    Swal.fire('Éxito', response.message, 'success').then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            },
            error: function(xhr) {
                const response = xhr.responseJSON;
                Swal.fire('Error', response?.message || 'Error al guardar el piloto', 'error');
            }
        });
    });

    // Eliminar piloto
    function eliminarPiloto(id) {
        const pilotoId = parseInt(id);
        
        Swal.fire({
            title: '¿Estás seguro?',
            text: 'Esta acción no se puede deshacer',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: `/admin/api/pilotos/${pilotoId}`,
                    method: 'DELETE',
                    success: function(response) {
                        if (response.success) {
                            Swal.fire('Eliminado', response.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function(xhr) {
                        const response = xhr.responseJSON;
                        Swal.fire('Error', response?.message || 'Error al eliminar el piloto', 'error');
                    }
                });
            }
        });
    }

    // Exportar pilotos
    function exportarPilotos() {
        window.location.href = '/admin/api/pilotos?export=true';
    }
</script>
