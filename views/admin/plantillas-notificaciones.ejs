<!-- Vista Plantillas de Notificaciones - Gestión de Plantillas -->
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="bi bi-bell"></i> Plantillas de Notificaciones</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#plantillaModal" onclick="limpiarFormulario()">
            <i class="bi bi-plus-circle"></i> Nueva Plantilla
        </button>
    </div>
</div>

<!-- Tabla de Plantillas -->
<div class="card mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table id="plantillasTable" class="table table-striped table-hover" style="width:100%">
                <thead>
                    <tr>
                        <th>Clave</th>
                        <th>Título</th>
                        <th>Mensaje</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (plantillas && plantillas.length > 0) { %>
                        <% plantillas.forEach(function(plantilla) { %>
                            <tr>
                                <td class="align-middle"><code><%= plantilla.clave %></code></td>
                                <td class="align-middle"><%= plantilla.titulo %></td>
                                <td class="align-middle"><small class="text-muted"><%= plantilla.mensaje.substring(0, 60) %>...</small></td>
                                <td class="align-middle">
                                    <% if (plantilla.activo) { %>
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Activo</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Inactivo</span>
                                    <% } %>
                                </td>
                                <td class="align-middle">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#plantillaModal" onclick="editarPlantilla('<%= plantilla.id %>')" title="Editar">
                                            <i class="bi bi-pencil-fill"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" onclick="eliminarPlantilla('<%= plantilla.id %>')" title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No hay plantillas registradas
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Card de Variables -->
<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-code-slash me-2"></i>Variables Disponibles</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h6 class="fw-bold text-uppercase text-muted" style="font-size: 0.75rem;">Para todas las plantillas:</h6>
                <ul class="list-unstyled">
                    <li><code>{moneda}</code> - Moneda del sistema (Bs)</li>
                </ul>
                
                <h6 class="fw-bold text-uppercase text-muted mt-3" style="font-size: 0.75rem;">PIN Verificación:</h6>
                <ul class="list-unstyled">
                    <li><code>{pin}</code> - Código PIN</li>
                    <li><code>{minutos}</code> - Minutos de expiración</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h6 class="fw-bold text-uppercase text-muted" style="font-size: 0.75rem;">Viajes:</h6>
                <ul class="list-unstyled">
                    <li><code>{origen}</code> - Dirección de origen</li>
                    <li><code>{destino}</code> - Dirección de destino</li>
                    <li><code>{distancia}</code> - Distancia en km</li>
                    <li><code>{tiempo}</code> - Tiempo estimado</li>
                    <li><code>{precio}</code> - Precio del viaje</li>
                </ul>
                
                <h6 class="fw-bold text-uppercase text-muted mt-3" style="font-size: 0.75rem;">Piloto:</h6>
                <ul class="list-unstyled">
                    <li><code>{piloto}</code> - Nombre del piloto</li>
                    <li><code>{placa}</code> - Placa del vehículo</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Modal para Crear/Editar Plantilla -->
<div class="modal fade" id="plantillaModal" tabindex="-1" aria-labelledby="plantillaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="plantillaModalLabel">
                    <i class="bi bi-bell-plus me-2"></i>Nueva Plantilla
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="plantillaForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="plantillaId">
                    
                    <!-- Sección: Información de la Plantilla -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-info-circle me-1"></i> Información de la Plantilla
                        </h6>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="clave" class="form-label fw-semibold">
                                    Clave <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-key-fill"></i></span>
                                    <input type="text" class="form-control" id="clave" placeholder="Ej: pin_verificacion" required>
                                </div>
                                <small class="text-muted">Identificador único (sin espacios)</small>
                            </div>
                            
                            <div class="col-md-6">
                                <label for="titulo" class="form-label fw-semibold">
                                    Título <span class="text-danger">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light"><i class="bi bi-type-h1"></i></span>
                                    <input type="text" class="form-control" id="titulo" placeholder="Ej: 🔐 Verificación MotoTaxi" required>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Mensaje -->
                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem;">
                            <i class="bi bi-chat-dots me-1"></i> Mensaje
                        </h6>
                        
                        <div class="row">
                            <div class="col-12">
                                <label for="mensaje" class="form-label fw-semibold">
                                    Plantilla del Mensaje <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control" id="mensaje" rows="6" placeholder="Usa variables como {variable} para personalizar" required></textarea>
                                <small class="text-muted">Usa variables como <code>{pin}</code>, <code>{minutos}</code>, <code>{moneda}</code>, etc.</small>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Sección: Estado -->
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="activo" checked>
                            <label class="form-check-label fw-semibold" for="activo">
                                Plantilla Activa
                            </label>
                            <small class="d-block text-muted">Si está desactivada, no se usará para enviar notificaciones</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light py-3">
                    <button type="button" class="btn btn-lg btn-outline-secondary px-4" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-2"></i>Cancelar
                    </button>
                    <button type="submit" class="btn btn-lg btn-primary px-4">
                        <i class="bi bi-check-circle me-2"></i>Guardar Plantilla
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Inicializar DataTable
    $(document).ready(function() {
        try {
            if ($.fn.DataTable.isDataTable('#plantillasTable')) {
                $('#plantillasTable').DataTable().destroy();
            }
            $('#plantillasTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                order: [[0, 'asc']],
                destroy: true
            });
        } catch(e) {
            console.log('DataTables error:', e);
        }
    });

    // Limpiar formulario
    function limpiarFormulario() {
        $('#plantillaId').val('');
        $('#plantillaForm')[0].reset();
        $('#clave').prop('disabled', false);
        $('#plantillaModalLabel').html('<i class="bi bi-bell-plus me-2"></i>Nueva Plantilla');
    }

    // Editar plantilla
    function editarPlantilla(id) {
        const plantillaId = id;
        
        $.ajax({
            url: '/admin/api/plantillas/' + id,
            method: 'GET',
            success: function(response) {
                if (response.success) {
                    const plantilla = response.data;
                    $('#plantillaId').val(plantilla.id);
                    $('#clave').val(plantilla.clave);
                    $('#clave').prop('disabled', true);
                    $('#titulo').val(plantilla.titulo);
                    $('#mensaje').val(plantilla.mensaje);
                    $('#activo').prop('checked', plantilla.activo === 1);
                    $('#plantillaModalLabel').html('<i class="bi bi-bell me-2"></i>Editar Plantilla');
                }
            },
            error: function() {
                Swal.fire('Error', 'No se pudo cargar la plantilla', 'error');
            }
        });
    }

    // Guardar plantilla
    $('#plantillaForm').on('submit', function(e) {
        e.preventDefault();
        
        const idValue = $('#plantillaId').val();
        const id = idValue ? parseInt(idValue) : null;
        
        const plantilla = {
            titulo: $('#titulo').val(),
            mensaje: $('#mensaje').val(),
            activo: $('#activo').is(':checked') ? 1 : 0
        };
        
        // Solo incluir clave si es nuevo
        if (!id) {
            plantilla.clave = $('#clave').val();
        }
        
        const url = id ? `/admin/api/plantillas/${id}` : '/admin/api/plantillas';
        const method = id ? 'PUT' : 'POST';
        
        $.ajax({
            url: url,
            method: method,
            contentType: 'application/json',
            data: JSON.stringify(plantilla),
            success: function(response) {
                if (response.success) {
                    Swal.fire('Éxito', response.message, 'success').then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            },
            error: function(xhr) {
                const response = xhr.responseJSON;
                Swal.fire('Error', response?.message || 'Error al guardar la plantilla', 'error');
            }
        });
    });

    // Eliminar plantilla
    function eliminarPlantilla(id) {
        Swal.fire({
            title: '¿Estás seguro?',
            text: 'Esta acción no se puede deshacer',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: `/admin/api/plantillas/${id}`,
                    method: 'DELETE',
                    success: function(response) {
                        if (response.success) {
                            Swal.fire('Eliminado', response.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function(xhr) {
                        const response = xhr.responseJSON;
                        Swal.fire('Error', response?.message || 'Error al eliminar la plantilla', 'error');
                    }
                });
            }
        });
    }
</script>
