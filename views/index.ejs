<%- include('layouts/header') %>

<!-- Hero Section -->
<section class="hero-section position-relative overflow-hidden">
    <div class="hero-overlay"></div>
    <div class="container position-relative z-index-1">
        <div class="row min-vh-100 align-items-center">
            <div class="col-lg-7">
                <span class="badge bg-danger mb-3 px-3 py-2">🚀 #1 en Transporte Rápido</span>
                <h1 class="display-3 fw-bold text-white mb-4">
                    Llega a tu destino <span class="text-warning">más rápido</span> y seguro
                </h1>
                <p class="lead text-white-50 mb-4">
                    Solicita un mototaxi con solo unos clics. Pilotos verificados, precios justos y seguimiento en tiempo real.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/pasajero" class="btn btn-warning btn-lg px-4 py-3 fw-bold">
                        <i class="bi bi-person-fill me-2"></i>¡Pide tu viaje!
                    </a>
                    <a href="/chofer" class="btn btn-outline-light btn-lg px-4 py-3">
                        <i class="bi bi-bicycle me-2"></i>Conductor
                    </a>
                </div>
                <div class="mt-5 d-flex align-items-center gap-4">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="bi bi-star-fill text-warning fs-4"></i>
                            <i class="bi bi-star-fill text-warning fs-4"></i>
                            <i class="bi bi-star-fill text-warning fs-4"></i>
                            <i class="bi bi-star-fill text-warning fs-4"></i>
                            <i class="bi bi-star-fill text-warning fs-4"></i>
                        </div>
                        <div>
                            <strong class="text-white">4.9/5</strong>
                            <p class="text-white-50 mb-0 small">+10,000 viajes</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="hero-mockup position-relative">
                    <div class="phone-mockup">
                        <div class="phone-screen">
                            <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&h=600&fit=crop" alt="App Preview" class="img-fluid rounded-3 shadow-lg">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Wave Divider -->
    <div class="hero-wave">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320">
            <path fill="#ffffff" fill-opacity="1" d="M0,96L48,112C96,128,192,160,288,165.3C384,171,480,149,576,128C672,107,768,85,864,90.7C960,96,1056,128,1152,138.7C1248,149,1344,139,1392,133.3L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
        </svg>
    </div>
</section>

<!-- How It Works Section -->
<section class="py-5" id="como-funciona">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="badge bg-primary-subtle text-primary px-3 py-2 mb-3">FÁCIL Y RÁPIDO</span>
            <h2 class="display-5 fw-bold">¿Cómo funciona?</h2>
            <p class="lead text-muted">En solo 3 pasos estarás en camino a tu destino</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 text-center step-card">
                    <div class="step-icon mx-auto mb-4">
                        <i class="bi bi-geo-alt fs-1"></i>
                    </div>
                    <h4 class="fw-bold">1. Indica tu destino</h4>
                    <p class="text-muted">Ingresa tu ubicación actual y destino. Nuestra app calcula la ruta más rápida.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 text-center step-card">
                    <div class="step-icon mx-auto mb-4">
                        <i class="bi bi-car-front fs-1"></i>
                    </div>
                    <h4 class="fw-bold">2. Un piloto llega a ti</h4>
                    <p class="text-muted">Un piloto cercano acepta tu solicitud y llega a recogerte en minutos.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 text-center step-card">
                    <div class="step-icon mx-auto mb-4">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                    <h4 class="fw-bold">3. Llega seguro</h4>
                    <p class="text-muted">Disfruta del viaje. Paga cuando llegues a tu destino.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light" id="servicios">
    <div class="container py-5">
        <div class="text-center mb-5">
            <span class="badge bg-warning-subtle text-warning px-3 py-2 mb-3">¿POR QUÉ ELEGIRNOS?</span>
            <h2 class="display-5 fw-bold">La mejor experiencia de transporte</h2>
            <p class="lead text-muted">Miles de usuarios nos prefieren por estas razones</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 feature-card">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h5 class="fw-bold">Rápido</h5>
                    <p class="text-muted mb-0">Pilotos cercanos siempre disponibles. Llega a tu destino en minutos.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 feature-card">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 class="fw-bold">Seguro</h5>
                    <p class="text-muted mb-0">Pilotos verificados y seguimiento en tiempo real de tu viaje.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 feature-card">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                    <h5 class="fw-bold">Económico</h5>
                    <p class="text-muted mb-0">Precios justos y transparentes. Sin sorpresas.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 feature-card">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <h5 class="fw-bold">Disponible 24/7</h5>
                    <p class="text-muted mb-0">Servicio disponible a cualquier hora, cualquier día.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- App Download Section -->
<section class="py-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <span class="badge bg-danger-subtle text-danger px-3 py-2 mb-3">DESCARGA LA APP</span>
                <h2 class="display-5 fw-bold mb-4">Lleva MotoTaxi en tu bolsillo</h2>
                <p class="lead text-muted mb-4">
                    Descarga nuestra app y solicita un viaje en cualquier momento. Disponible para Android y iOS.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="#" class="btn btn-dark btn-lg px-4">
                        <i class="bi bi-google-play me-2"></i>Google Play
                    </a>
                    <a href="#" class="btn btn-dark btn-lg px-4">
                        <i class="bi bi-apple me-2"></i>App Store
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="card border-0 shadow-sm p-3 text-center">
                            <i class="bi bi-people-fill text-primary fs-1 mb-2"></i>
                            <h4 class="fw-bold mb-1">500+</h4>
                            <p class="text-muted mb-0">Pilotos activos</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card border-0 shadow-sm p-3 text-center">
                            <i class="bi bi-car-front-fill text-success fs-1 mb-2"></i>
                            <h4 class="fw-bold mb-1">10,000+</h4>
                            <p class="text-muted mb-0">Viajes realizados</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card border-0 shadow-sm p-3 text-center">
                            <i class="bi bi-star-fill text-warning fs-1 mb-2"></i>
                            <h4 class="fw-bold mb-1">4.9</h4>
                            <p class="text-muted mb-0">Calificación</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card border-0 shadow-sm p-3 text-center">
                            <i class="bi bi-clock-history text-info fs-1 mb-2"></i>
                            <h4 class="fw-bold mb-1"><5 min</h4>
                            <p class="text-muted mb-0">Tiempo de espera</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-primary">
    <div class="container py-5 text-center">
        <h2 class="display-5 fw-bold text-white mb-3">¿Listo para empezar?</h2>
        <p class="lead text-white-50 mb-4">Únete a miles de usuarios que ya disfrutan de nuestro servicio</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/pasajero" class="btn btn-warning btn-lg px-5 py-3 fw-bold">
                <i class="bi bi-person-fill me-2"></i>Pedir un viaje
            </a>
            <a href="/chofer" class="btn btn-outline-light btn-lg px-5 py-3">
                <i class="bi bi-bicycle me-2"></i>Conviértete en piloto
            </a>
        </div>
    </div>
</section>

<style>
/* Hero Section Styles */
.hero-section {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    min-height: 100vh;
}

.hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.05"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
}

.hero-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    line-height: 0;
}

.z-index-1 {
    z-index: 1;
}

/* Step Card Animation */
.step-card {
    transition: transform 0.3s ease;
}

.step-card:hover {
    transform: translateY(-10px);
}

.step-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
}

/* Feature Card */
.feature-card {
    transition: transform 0.3s ease;
}

.feature-card:hover {
    transform: translateY(-5px);
}

.feature-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    background: #fff3cd;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #ffc107;
}

/* Phone Mockup */
.phone-mockup {
    position: relative;
}

.phone-screen {
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    border: 8px solid #1a1a2e;
}
</style>

<%- include('layouts/footer') %>
